# Enterprise Marketplace - Local Infrastructure Environment
# Copy to .env and adjust values: cp .env.example .env

# Keycloak
KEYCLOAK_PORT=8180
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_REALM=marketplace
KEYCLOAK_CLIENT_ID=marketplace-gateway
KEYCLOAK_CLIENT_SECRET=marketplace-gateway-secret

# Redis
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=

# Kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_UI_PORT=8099

# Elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_URIS=http://localhost:9200

# Kibana
KIBANA_PORT=5601

# Ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
JAEGER_UI_PORT=16686
JAEGER_OTLP_HTTP_PORT=4318
JAEGER_OTLP_GRPC_PORT=4317
ZIPKIN_PORT=9411
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Neon PostgreSQL (per-service - override per deployment)
NEON_DB_URL=jdbc:postgresql://localhost:5432/identity_service
NEON_DB_USER=marketplace
NEON_DB_PASSWORD=marketplace
NEON_DB_SSL_MODE=prefer

# Spring
SPRING_PROFILES_ACTIVE=local

# Service hosts (for gateway routing when running locally)
GATEWAY_PORT=8080
IDENTITY_SERVICE_HOST=localhost
IDENTITY_SERVICE_PORT=8081
SEARCH_SERVICE_HOST=localhost
SEARCH_SERVICE_PORT=8090
AI_SERVICE_HOST=localhost
AI_SERVICE_PORT=8091
