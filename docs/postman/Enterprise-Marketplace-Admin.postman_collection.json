{
  "info": {
    "name": "Enterprise Marketplace - Admin Service",
    "description": "Platform administration API with JWT (ADMIN role required)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8095" },
    { "key": "gatewayUrl", "value": "http://localhost:8080/api/admin" },
    { "key": "settingKey", "value": "integration.test.setting" },
    { "key": "configKey", "value": "integration.test.config" },
    { "key": "flagKey", "value": "feature.ai.enabled" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "Actuator Health", "request": { "method": "GET", "url": "{{baseUrl}}/actuator/health" } },
        { "name": "Bootstrap Health", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/bootstrap/health" } }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "List Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/settings"
          }
        },
        {
          "name": "List Settings By Category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/settings?category=GENERAL"
          }
        },
        {
          "name": "Create Setting",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settingKey\": \"{{settingKey}}\",\n  \"settingValue\": \"enabled\",\n  \"category\": \"TEST\",\n  \"description\": \"Postman test setting\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/settings"
          }
        },
        {
          "name": "Update Setting",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settingValue\": \"updated-value\",\n  \"category\": \"TEST\",\n  \"description\": \"Updated via Postman\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/settings/{{settingKey}}"
          }
        },
        {
          "name": "Delete Setting",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/settings/{{settingKey}}"
          }
        }
      ]
    },
    {
      "name": "Feature Flags",
      "item": [
        {
          "name": "List Feature Flags",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/feature-flags"
          }
        },
        {
          "name": "Get Feature Flag",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/feature-flags/{{flagKey}}"
          }
        },
        {
          "name": "Patch Feature Flag",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true,\n  \"rolloutPercentage\": 100,\n  \"description\": \"AI feature enabled via Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/feature-flags/{{flagKey}}"
          }
        },
        {
          "name": "Bulk Patch Feature Flags",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"updates\": [\n    { \"flagKey\": \"feature.ai.enabled\", \"enabled\": true, \"rolloutPercentage\": 100 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/feature-flags"
          }
        }
      ]
    },
    {
      "name": "Configs",
      "item": [
        {
          "name": "List Configs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/configs"
          }
        },
        {
          "name": "Create Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"configKey\": \"{{configKey}}\",\n  \"configValue\": { \"timeoutSeconds\": 30, \"maxRetries\": 3 },\n  \"scope\": \"GLOBAL\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/configs"
          }
        },
        {
          "name": "Update Config",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"configValue\": { \"timeoutSeconds\": 60, \"maxRetries\": 5 },\n  \"scope\": \"GLOBAL\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/configs/{{configKey}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/dashboard"
          }
        }
      ]
    }
  ]
}
